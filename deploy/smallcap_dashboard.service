[Unit]
Description=Small Cap Dashboard (port 8889)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=trading
Group=trading
WorkingDirectory=/home/trading/trading_system
ExecStart=/home/trading/trading_system/venv/bin/python -m uvicorn smallcap.dashboard.server:app --host 0.0.0.0 --port 8889
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
